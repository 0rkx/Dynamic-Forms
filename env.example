# ==============================================
# SUPABASE CONFIGURATION
# ==============================================
# Your Supabase project URL (found in project settings)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase publishable key (recommended) or legacy anon key
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
# VITE_SUPABASE_ANON_KEY=your-legacy-anon-public-key-here

# ==============================================
# AI CONFIGURATION
# ==============================================
# Gemini AI API key for intelligent form features
# Get your key from: https://makersuite.google.com/app/apikey
# Set this as a Cloudflare Worker secret, not a frontend build variable.
GEMINI_API_KEY=your-gemini-api-key-here

# ==============================================
# GOOGLE SHEETS INTEGRATION
# ==============================================
# Google API credentials for Google Sheets export
# Get your credentials from: https://console.developers.google.com/
# 1. Create a new project or select existing one
# 2. Enable Google Sheets API
# 3. Create credentials (OAuth 2.0 Client ID for web application)
# 4. Add your domain to authorized origins
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=your-google-api-key-here

# ==============================================
# BACKEND CONFIGURATION
# ==============================================
# Cloudflare Worker API routes are same-origin in production.
# Leave empty unless you intentionally want another API host.
VITE_API_URL=

# Cloudflare Worker CORS allowlist.
# Set as a Cloudflare Worker secret or variable, for example:
#   https://dynamic-forms.pages.dev,http://localhost:5173,http://127.0.0.1:5173
ALLOWED_ORIGINS=https://your-production-domain.example

# Cloudflare Worker auth verification.
# Set these on the Worker, not as frontend-only Pages variables.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# ==============================================
# OPTIONAL CONFIGURATION
# ==============================================
# Enable debug logging (true/false)
# Set to 'true' to enable detailed console logging in production
VITE_DEBUG=false

# Maximum file upload size in MB
VITE_MAX_UPLOAD_SIZE=10

# ==============================================
# SETUP INSTRUCTIONS
# ==============================================
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual keys
# 3. Never commit your .env file to version control
# 4. Restart your development server after making changes
