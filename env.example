# ==============================================
# SUPABASE CONFIGURATION
# ==============================================
# Your Supabase project URL (found in project settings)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (found in project API settings)
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ==============================================
# AI CONFIGURATION
# ==============================================
# Gemini AI API key for intelligent form features
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ==============================================
# GOOGLE SHEETS INTEGRATION
# ==============================================
# Google API credentials for Google Sheets export
# Get your credentials from: https://console.developers.google.com/
# 1. Create a new project or select existing one
# 2. Enable Google Sheets API
# 3. Create credentials (OAuth 2.0 Client ID for web application)
# 4. Add your domain to authorized origins
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=your-google-api-key-here

# ==============================================
# BACKEND CONFIGURATION
# ==============================================
# Backend API URL (Edge Function base). For local dev with `supabase functions serve` use:
#   http://localhost:54321/functions/v1/ai
# In production replace <project-ref> with your Supabase project ref, e.g.
#   https://<project-ref>.supabase.co/functions/v1/ai
VITE_API_URL=https://<project-ref>.supabase.co/functions/v1/ai

# ==============================================
# OPTIONAL CONFIGURATION
# ==============================================
# Application environment
NODE_ENV=development

# Enable debug logging (true/false)
# Set to 'true' to enable detailed console logging in production
VITE_DEBUG=false

# Maximum file upload size in MB
VITE_MAX_UPLOAD_SIZE=10

# ==============================================
# SETUP INSTRUCTIONS
# ==============================================
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual keys
# 3. Never commit your .env file to version control
# 4. Restart your development server after making changes 